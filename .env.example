# Copy this file to .env and fill in your real values.
# Never commit the real .env to git.

# --- Twilio credentials (https://console.twilio.com) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# --- WhatsApp numbers ---
# Twilio sandbox number (leave as-is for sandbox mode)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Your own WhatsApp number in E.164 format with the whatsapp: prefix
YOUR_WHATSAPP_NUMBER=whatsapp:+16314082331

# --- End-of-day summary schedule (24h clock, America/Los_Angeles timezone) ---
EOD_HOUR=18
EOD_MINUTE=0
